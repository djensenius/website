---
const defaultPlausibleSrc = 'https://plausible.io/js/script.js';
const plausibleDomain = import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN?.trim();
const configuredPlausibleSrc = import.meta.env.PUBLIC_PLAUSIBLE_SRC;
const plausibleSrc =
  configuredPlausibleSrc === undefined
    ? defaultPlausibleSrc
    : validateScriptSrc(configuredPlausibleSrc.trim());

function validateScriptSrc(src: string): string {
  if (isAllowedScriptSrc(src)) return src;
  throw new Error(
    'Invalid PUBLIC_PLAUSIBLE_SRC. Use an absolute https:// URL or root-relative /path. http:// is allowed only during local dev.',
  );
}

function isAllowedScriptSrc(src: string): boolean {
  if (!src) return false;
  if (src.startsWith('/')) return !src.startsWith('//');
  try {
    const { protocol } = new URL(src);
    return protocol === 'https:' || (import.meta.env.DEV && protocol === 'http:');
  } catch {
    return false;
  }
}
---

{
  plausibleDomain && (
    <script is:inline defer data-domain={plausibleDomain} src={plausibleSrc}></script>
  )
}
