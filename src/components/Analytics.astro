---
const defaultPlausibleSrc = 'https://plausible.io/js/script.js';
const plausibleDomain = import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN?.trim();
const configuredPlausibleSrc = import.meta.env.PUBLIC_PLAUSIBLE_SRC?.trim();
const plausibleSrc = isAllowedScriptSrc(configuredPlausibleSrc)
  ? configuredPlausibleSrc
  : defaultPlausibleSrc;

function isAllowedScriptSrc(src: string | undefined): src is string {
  if (!src) return false;
  if (src.startsWith('/')) return !src.startsWith('//');
  try {
    const { protocol } = new URL(src);
    return protocol === 'http:' || protocol === 'https:';
  } catch {
    return false;
  }
}
---

{
  plausibleDomain && (
    <script is:inline defer data-domain={plausibleDomain} src={plausibleSrc}></script>
  )
}
