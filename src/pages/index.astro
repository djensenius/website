---
// Landing shell (issue #34). The modernized site opens on the in-browser Linux
// emulator — the signature terminal experience — with light branding and a link
// to the plain file-navigation view. A proper emulator↔file-nav toggle comes in
// issue #35.
import Emulator from '../components/Emulator.astro';
const title = 'David Jensenius';
const base = import.meta.env.BASE_URL;
const filesHref = `${base}files/`.replace(/\/{2,}/g, '/');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta
      name="description"
      content="David Jensenius — composer and media artist. A tiny Linux, running in your browser, holding his work."
    />
  </head>
  <body>
    <main class="shell">
      <header class="masthead">
        <h1>{title}</h1>
        <p class="tagline">
          Composer and media artist. This site is a tiny Linux running in your
          browser — your files are in <code>/mnt</code>. Prefer plain pages?
          <a href={filesHref}>Browse the files</a>.
        </p>
      </header>
      <Emulator />
    </main>

    <style>
      :root {
        color-scheme: light dark;
        --shell-bg: #0b0b0b;
        --shell-fg: #d7d7d7;
        --shell-muted: #8a8a8a;
        --shell-link: #7aa2f7;
      }

      @media (prefers-color-scheme: light) {
        :root {
          --shell-bg: #fbfbfa;
          --shell-fg: #1a1a1a;
          --shell-muted: #6a6a6a;
          --shell-link: #1d4ed8;
        }
      }

      body {
        margin: 0;
        background: var(--shell-bg);
        color: var(--shell-fg);
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
      }

      .shell {
        max-width: 60rem;
        margin: 0 auto;
        padding: 1.5rem 1rem 2.5rem;
      }

      .masthead {
        margin-bottom: 1.25rem;
      }

      .masthead h1 {
        margin: 0 0 0.25rem;
        font-size: 1.5rem;
      }

      .tagline {
        margin: 0;
        max-width: 46rem;
        color: var(--shell-muted);
        line-height: 1.5;
      }

      .tagline a {
        color: var(--shell-link);
      }
    </style>
  </body>
</html>
