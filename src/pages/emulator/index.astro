---
// Standalone full-page emulator route. The emulator itself lives in a reusable
// component (issue #34) so the landing shell and this route share one boot path.
import BaseHead from '../../components/BaseHead.astro';
import Emulator from '../../components/Emulator.astro';
import Analytics from '../../components/Analytics.astro';
import ModeToggle from '../../components/ModeToggle.astro';

const title = 'Emulator — David Jensenius';
const description =
  'A browser-based terminal entrance to the work and portfolio of David Jensenius, composer and media artist.';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <BaseHead title={title} description={description} path="/emulator/" />
    <Analytics />
  </head>
  <body>
    <div class="shell">
      <header class="topbar">
        <ModeToggle active="terminal" />
      </header>
      <main class="stage">
        <Emulator />
      </main>
    </div>

    <style>
      :root {
        color-scheme: light dark;
        --shell-bg: #0b0b0b;
        --shell-fg: #d7d7d7;
      }

      @media (prefers-color-scheme: light) {
        :root {
          --shell-bg: #fbfbfa;
          --shell-fg: #1a1a1a;
        }
      }

      html,
      body {
        height: 100%;
      }

      body {
        margin: 0;
        background: var(--shell-bg);
        color: var(--shell-fg);
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
      }

      /* Full-viewport column: a slim bar with the mode toggle, then the
       * emulator filling all remaining height. */
      .shell {
        display: flex;
        flex-direction: column;
        height: 100vh;
        height: 100dvh;
        padding: 1rem;
        box-sizing: border-box;
      }

      .topbar {
        flex: 0 0 auto;
        display: flex;
        justify-content: flex-end;
        margin-bottom: 0.75rem;
      }

      .stage {
        flex: 1 1 auto;
        min-height: 0;
        display: flex;
      }
    </style>
  </body>
</html>
