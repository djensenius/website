---
// Standalone full-page emulator route. The emulator itself lives in a reusable
// component (issue #34) so the landing shell and this route share one boot path.
import Emulator from '../../components/Emulator.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Emulator — David Jensenius</title>
    <meta
      name="description"
      content="A tiny Linux, running in your browser, holding the work of David Jensenius."
    />
  </head>
  <body>
    <main class="stage">
      <Emulator />
    </main>

    <style>
      :root {
        color-scheme: light dark;
        --shell-bg: #0b0b0b;
        --shell-fg: #d7d7d7;
      }

      @media (prefers-color-scheme: light) {
        :root {
          --shell-bg: #fbfbfa;
          --shell-fg: #1a1a1a;
        }
      }

      html,
      body {
        height: 100%;
      }

      body {
        margin: 0;
        background: var(--shell-bg);
        color: var(--shell-fg);
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
      }

      /* Full-viewport emulator. */
      .stage {
        display: flex;
        height: 100vh;
        height: 100dvh;
        padding: 1rem;
        box-sizing: border-box;
      }
    </style>
  </body>
</html>
